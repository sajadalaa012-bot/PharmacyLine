# Copy these into your host's environment variables (Railway → Variables).

# REQUIRED — the password used to sign in to the app. Pick something strong.
ADMIN_PASSWORD=change-this-to-a-strong-password

# Optional — independent secret for signing the session token.
# Defaults to ADMIN_PASSWORD if unset. Set it so tokens don't change
# when you rotate the password.
# AUTH_SECRET=some-long-random-string

# Set automatically by the host (Railway injects PORT). Leave unset locally.
# PORT=8000

# Persistent data directory (SQLite + uploads). The Dockerfile sets this to
# /data — point your mounted volume there.
# DATA_DIR=/data
