# Copy to `.env.local` for local dev, and set the same in Vercel → Settings →
# Environment Variables for production. These are SERVER-ONLY (no NEXT_PUBLIC_
# prefix) so they never reach the browser.

# Postgres connection string (Neon / Vercel Postgres / Supabase).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin login for the back office (/admin) + all admin API routes.
ADMIN_EMAIL=pharmacyline@gmail.com
ADMIN_PASSWORD=pharmacyline

# Secret used to sign the admin session cookie. Use a long random string.
AUTH_SECRET=change-me-to-a-long-random-string
